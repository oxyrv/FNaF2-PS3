    o_Cam_Btn.visible = false;
    instance_create(0,0,o_Mask);
    global.IsMaskOn = 1;
}

if (instance_exists(o_Maskoff_Anim) &amp;&amp; o_Maskoff_Anim.image_index &gt;= o_Maskoff_Anim.image_number - 1)
{
