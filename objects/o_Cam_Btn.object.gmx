        <arguments>
          <argument>
            <kind>1</kind>
            <string>var axis_val = gamepad_axis_value(0, gp_axisrv);

if (!instance_exists(o_Camon_Anim) &amp;&amp; !instance_exists(o_Camoff_Anim) &amp;&amp; !instance_exists(o_Maskon_Anim) &amp;&amp; !instance_exists(o_Maskoff_Anim))
{
    if (axis_val &gt; 0.8 &amp;&amp; global.IsMaskOn == 0 &amp;&amp; global.IsCamOn == 0)
    {
        if instance_exists(o_Office_Light_Front)
        {
            instance_destroy(o_Office_Light_Front);
            sound_stop(buzzlight);
        }
        if instance_exists(o_Office_Left_Light)
        {
            instance_destroy(o_Office_Left_Light);
            sound_stop(buzzlight);
        }
        if instance_exists(o_Office_Right_Light)
        {
            instance_destroy(o_Office_Right_Light);
            sound_stop(buzzlight);
        }
        if (o_Btn_Left.visible = true)
        {
            o_Btn_Left.visible = false;
        }
        if (o_Btn_Right.visible = true)
        {
            o_Btn_Right.visible = false;
        }
        instance_create(0,0,o_Camon_Anim);
    }

    if (axis_val &lt; -0.8 &amp;&amp; global.IsCamOn == 1 &amp;&amp; global.CamLight == 0)
    {
        instance_create(0,0,o_Camoff_Anim);
        instance_destroy(o_Cam_Main);
        instance_destroy(o_Layer);
    }
}

if (instance_exists(o_Camon_Anim) &amp;&amp; o_Camon_Anim.image_index &gt;= o_Camon_Anim.image_number - 1)
{
    global.IsCamOn = 1;
    instance_destroy(o_Camon_Anim);
    o_Mask_Btn_On.visible = false;
    instance_create(0,0,o_Cam_Main);
    instance_create(0,0,o_Layer);
}

if (instance_exists(o_Camoff_Anim) &amp;&amp; o_Camoff_Anim.image_index &gt;= o_Camoff_Anim.image_number - 1)
{
    global.IsCamOn = 0;
    instance_destroy(o_Camoff_Anim);
    o_Mask_Btn_On.visible = true;
}
</string>
